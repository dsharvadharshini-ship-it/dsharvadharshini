<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEC Student Login</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Segoe UI, Arial, sans-serif;
}

body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#8B0000,#C62828,#F5F5F5);
}

.login-box{
    width:380px;
    background:#fff;
    border-radius:15px;
    padding:35px;
    text-align:center;
    box-shadow:0 10px 25px rgba(0,0,0,0.3);
}

.logo{
    width:120px;
    margin-bottom:15px;
}

h2{
    color:#8B0000;
    margin-bottom:5px;
}

p{
    color:#666;
    margin-bottom:25px;
}

.input-group{
    margin-bottom:18px;
}

input{
    width:100%;
    padding:12px;
    border:1px solid #ccc;
    border-radius:8px;
    font-size:15px;
    outline:none;
}

input:focus{
    border-color:#8B0000;
}

button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:8px;
    background:#8B0000;
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    background:#A00000;
}

.links{
    margin-top:15px;
    font-size:14px;
}

.links a{
    text-decoration:none;
    color:#8B0000;
}

.footer{
    margin-top:20px;
    font-size:12px;
    color:#777;
}
</style>

</head>
<body>

<div class="login-box">

    <img src="logo.jpeg" alt="College Logo" class="logo">

    <h2>Adhiparasakthi Engineering College</h2>

    <p>Student Login Portal</p>

    <form onsubmit="return login()">

        <div class="input-group">
            <input type="text" id="username" placeholder="Username" required>
        </div>

        <div class="input-group">
            <input type="password" id="password" placeholder="Password" required>
        </div>

        <button type="submit">Login</button>

    </form>

    <div class="links">
        <a href="#">Forgot Password?</a>
    </div>

    <div class="footer">
        © 2026 Adhiparasakthi Engineering College
    </div>

</div>

<script>
function login(){

    var username=document.getElementById("username").value;
    var password=document.getElementById("password").value;

    // Demo login
    if(username==="admin" && password==="admin123"){
        alert("Login Successful!");
        window.location.href="home.html";
    }
    else{
        alert("Invalid Username or Password");
    }

    return false;
}
</script>

</body>
</html>
